<Window x:Class="ImageAiEnhancerApp.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:ImageAiEnhancerApp.App.Views"
        mc:Ignorable="d"
        Title="Image AI Enhancer App (Offline)"
        Height="840"
        Width="1400"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#FFF1F5F9">
        <Border Margin="10"
                Background="White"
                CornerRadius="10"
                BorderBrush="#FFCBD5E1"
                BorderThickness="1"
                Padding="6">
            <TabControl>
                <TabItem Header="Single Image">
                    <views:SingleImageView DataContext="{Binding SingleImage}" />
                </TabItem>
                <TabItem Header="Batch">
                    <views:BatchView DataContext="{Binding Batch}" />
                </TabItem>
                <TabItem Header="Models / Settings">
                    <views:ModelsView DataContext="{Binding Models}" />
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
