<UserControl x:Class="ImageAiEnhancerApp.App.Views.ModelsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1000">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Models &amp; Settings"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,10" />

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">
            <Button Content="Open Models Folder"
                    Width="160"
                    Height="30"
                    Margin="0,0,8,0"
                    Command="{Binding OpenModelsFolderCommand}" />
            <Button Content="Reload Models"
                    Width="120"
                    Height="30"
                    Margin="0,0,16,0"
                    Command="{Binding ReloadModelsCommand}" />

            <CheckBox Content="Prefer DirectML GPU"
                      VerticalAlignment="Center"
                      IsChecked="{Binding UseGpuIfAvailable}" />

            <TextBlock Margin="18,0,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding IsDirectMlAvailable, StringFormat=DirectML available: {0}}" />

            <TextBlock Margin="18,0,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding ActiveProvider, StringFormat=Current provider: {0}}" />
        </StackPanel>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Models}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="2*" />
                <DataGridTextColumn Header="Scale" Binding="{Binding Scale}" Width="*" />
                <DataGridCheckBoxColumn Header="Exists" Binding="{Binding Exists}" Width="*" />
                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
